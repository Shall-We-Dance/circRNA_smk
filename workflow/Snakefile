configfile: "config.yaml"

include: "rules/helpers.smk"
include: "rules/qc_fastp.smk"
include: "rules/align_star.smk"
include: "rules/featurecount.smk"
include: "rules/ciri3.smk"
include: "rules/motif.smk"
include: "rules/splicing_stats.smk"
include: "rules/deg.smk"

rule all:
    input:
        # fastp sample-level QC
        expand(f"{OUTDIR}/qc/fastp/{{sample}}/fastp.html", sample=SAMPLES),
        expand(f"{OUTDIR}/qc/fastp/{{sample}}/fastp.json", sample=SAMPLES),

        # STAR outputs
        expand(f"{OUTDIR}/star/{{sample}}/{{sample}}.Log.final.out", sample=SAMPLES),
        expand(f"{OUTDIR}/star/{{sample}}/{{sample}}.SJ.out.tab", sample=SAMPLES),

        # featureCounts + CIRI3
        f"{OUTDIR}/featurecount/totalRNA.counts.txt",
        expand(f"{OUTDIR}/ciri3/per_sample/{{sample}}.ciri3", sample=SAMPLES),
        expand(f"{OUTDIR}/ciri3/per_sample/{{sample}}.ciri3.BSJ_Matrix", sample=SAMPLES),
        expand(f"{OUTDIR}/ciri3/per_sample/{{sample}}.ciri3.FSJ_Matrix", sample=SAMPLES),
        f"{OUTDIR}/ciri3/all_samples.ciri3",
        f"{OUTDIR}/ciri3/all_samples.ciri3.BSJ_Matrix",
        f"{OUTDIR}/ciri3/all_samples.ciri3.FSJ_Matrix",

        # splicing summaries
        *expand(f"{OUTDIR}/splicing/{{sample}}/circ_splice_sites.tsv", sample=SAMPLES),
        *expand(f"{OUTDIR}/splicing/{{sample}}/summary.tsv", sample=SAMPLES),
        *expand(f"{OUTDIR}/splicing/{{sample}}/distributions.tsv", sample=SAMPLES),
        *expand(f"{OUTDIR}/splicing/{{sample}}/alternative_back_splicing.tsv", sample=SAMPLES),
        *expand(f"{OUTDIR}/splicing/{{sample}}/distribution.png", sample=SAMPLES),
        f"{OUTDIR}/splicing/all_samples_summary.tsv",
        f"{OUTDIR}/splicing/all_samples_distributions.tsv",
        f"{OUTDIR}/splicing/all_samples_alternative_back_splicing.tsv",
        f"{OUTDIR}/splicing/all_samples_overview.png",

        # motif outputs
        *(
            [
                *expand(f"{OUTDIR}/motif/{{sample}}/bsj_sites.tsv", sample=SAMPLES),
                *expand(
                    f"{OUTDIR}/motif/{{sample}}/bsj_motif_summary.tsv",
                    sample=SAMPLES,
                ),
                *expand(
                    f"{OUTDIR}/motif/{{sample}}/homer/knownResults.txt",
                    sample=SAMPLES,
                ),
                f"{OUTDIR}/motif/all_samples_site_stats.tsv",
                f"{OUTDIR}/motif/all_samples_known_motif_summary.tsv",
                f"{OUTDIR}/motif/all_samples_homer_summary.tsv",
                f"{OUTDIR}/motif/all_samples_top_known_motifs.tsv",
                f"{OUTDIR}/motif/all_samples_overview.png",
                f"{OUTDIR}/motif/all_samples_known_motif_heatmap.png",
            ]
            if MOTIF_ENABLED
            else []
        ),

        # summary QC
        f"{OUTDIR}/qc/multiqc/multiqc_report.html",

        # custom BSJ differential expression (DESeq2)
        *(
            [
                f"{OUTDIR}/deg/deseq2/sample_metadata.tsv",
                f"{OUTDIR}/deg/deseq2/all_groups/deseq2_results.tsv",
                f"{OUTDIR}/deg/deseq2/all_groups/heatmap_top50.pdf",
                f"{OUTDIR}/deg/deseq2/all_groups/pca.pdf",
                f"{OUTDIR}/deg/deseq2/all_groups/vst_counts.tsv",
            ]
            + [
                f"{OUTDIR}/deg/deseq2/pairwise/{comparison}/deseq2_results.tsv"
                for comparison in DEG_COMPARISON_NAMES
            ]
            + [
                f"{OUTDIR}/deg/deseq2/pairwise/{comparison}/volcano.pdf"
                for comparison in DEG_COMPARISON_NAMES
            ]
            + [
                f"{OUTDIR}/deg/deseq2/pairwise/{comparison}/volcano_labeled.pdf"
                for comparison in DEG_COMPARISON_NAMES
            ]
            + [
                f"{OUTDIR}/deg/deseq2/pairwise/{comparison}/heatmap_top50.pdf"
                for comparison in DEG_COMPARISON_NAMES
            ]
            + [
                f"{OUTDIR}/deg/deseq2/pairwise/{comparison}/pca.pdf"
                for comparison in DEG_COMPARISON_NAMES
            ]
            if DEG_RUN_DESEQ2
            else []
        ),

        # native CIRI3 differential expression
        *(
            (
                [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_bsj/result.txt"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_bsj/{plot}.pdf"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                    for plot in ["heatmap_top50", "pca", "volcano", "volcano_labeled"]
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/all_groups/de_bsj/{plot}.pdf"
                    for plot in ["heatmap_top50", "pca"]
                ]
                if CIRI3_DE_RUN_BSJ
                else []
            )
            + (
                [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_ratio/result.txt"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_ratio/{plot}.pdf"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                    for plot in ["heatmap_top50", "pca", "volcano", "volcano_labeled"]
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/all_groups/de_ratio/{plot}.pdf"
                    for plot in ["heatmap_top50", "pca"]
                ]
                if CIRI3_DE_RUN_RATIO
                else []
            )
            + (
                [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_relative/result.txt"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/{comparison}/de_relative/{plot}.pdf"
                    for comparison in CIRI3_DE_COMPARISON_NAMES
                    for plot in ["heatmap_top50", "pca", "volcano", "volcano_labeled"]
                ]
                + [
                    f"{CIRI3_DE_OUTDIR}/all_groups/de_relative/{plot}.pdf"
                    for plot in ["heatmap_top50", "pca"]
                ]
                if CIRI3_DE_RUN_RELATIVE
                else []
            )
            if CIRI3_DE_ENABLED
            else []
        )
